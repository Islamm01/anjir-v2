generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  phone      String   @unique
  name       String?
  email      String?
  avatarUrl  String?
  role       UserRole @default(CUSTOMER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  storeProfile   Store?
  courierProfile Courier?
  orders         Order[]
  deliveries     Delivery[]
  otpCodes       OtpCode[]

  @@index([phone])
  @@index([role])
}

enum UserRole {
  CUSTOMER
  STORE_OWNER
  COURIER
  ADMIN
  OPERATOR
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String?
  phone     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id])
  @@index([phone])
}

model Store {
  id            String   @id @default(cuid())
  userId        String   @unique
  slug          String   @unique
  name          String
  description   String?  @db.Text
  phone         String
  address       String
  city          String   @default("Худжанд")
  logoUrl       String?
  bannerUrl     String?
  commissionPct Decimal  @db.Decimal(5, 2) @default(12.0)
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  isOpen        Boolean  @default(true)
  openTime      String?
  closeTime     String?
  avgPrepMins   Int      @default(30)
  totalOrders   Int      @default(0)
  rating        Decimal  @db.Decimal(3, 2) @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner    User          @relation(fields: [userId], references: [id])
  products Product[]
  orders   Order[]
  payouts  StorePayout[]

  @@index([slug])
  @@index([isActive, isVerified])
}

model Product {
  id          String          @id @default(cuid())
  storeId     String
  nameRu      String
  nameTj      String?
  description String?         @db.Text
  category    ProductCategory
  price       Decimal         @db.Decimal(10, 2)
  unit        String          @default("кг")
  imageUrl    String?
  stockQty    Decimal?        @db.Decimal(10, 2)
  isAvailable Boolean         @default(true)
  isFeatured  Boolean         @default(false)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  store      Store       @relation(fields: [storeId], references: [id])
  orderItems OrderItem[]

  @@index([storeId, isAvailable])
}

enum ProductCategory {
  FRUITS
  DRIED_FRUITS
  NUTS
  VEGETABLES
  HERBS
  OTHER
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String
  storeId         String
  courierId       String?
  status          OrderStatus   @default(NEW_ORDER)
  subtotal        Decimal       @db.Decimal(12, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2) @default(10)
  commission      Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?
  deliveryAddress String
  deliveryNotes   String?       @db.Text
  rejectedReason  String?
  cancelledReason String?
  storeConfirmedAt    DateTime?
  preparingStartedAt  DateTime?
  readyAt             DateTime?
  courierAssignedAt   DateTime?
  pickedUpAt          DateTime?
  deliveredAt         DateTime?
  completedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer   User             @relation(fields: [customerId], references: [id])
  store      Store            @relation(fields: [storeId], references: [id])
  courier    Courier?         @relation(fields: [courierId], references: [id])
  items      OrderItem[]
  statusLogs OrderStatusLog[]
  payment    Payment?

  @@index([customerId])
  @@index([storeId, status])
  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  unitPrice   Decimal @db.Decimal(10, 2)
  unit        String
  quantity    Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
  @@index([orderId])
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  actorId   String?
  actorRole String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([orderId])
}

enum OrderStatus {
  NEW_ORDER
  STORE_CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  COURIER_ASSIGNED
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  COMPLETED
  REJECTED
  CANCELLED
}

model Delivery {
  id             String         @id @default(cuid())
  deliveryNumber String         @unique
  customerId     String
  courierId      String?
  status         DeliveryStatus @default(REQUESTED)
  pickupAddress  String
  pickupName     String?
  pickupPhone    String?
  dropoffAddress String
  dropoffName    String
  dropoffPhone   String
  description    String?        @db.Text
  isFragile      Boolean        @default(false)
  price          Decimal        @db.Decimal(10, 2)
  paymentMethod  PaymentMethod  @default(CASH)
  paymentStatus  PaymentStatus  @default(PENDING)
  courierAcceptedAt DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  cancelledReason   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer   User                @relation(fields: [customerId], references: [id])
  courier    Courier?            @relation(fields: [courierId], references: [id])
  payment    Payment?
  statusLogs DeliveryStatusLog[]

  @@index([customerId])
  @@index([courierId])
  @@index([status])
}

model DeliveryStatusLog {
  id         String         @id @default(cuid())
  deliveryId String
  status     DeliveryStatus
  note       String?
  actorId    String?
  createdAt  DateTime       @default(now())
  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  @@index([deliveryId])
}

enum DeliveryStatus {
  REQUESTED
  ACCEPTED
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

model Courier {
  id              String      @id @default(cuid())
  userId          String      @unique
  vehicleType     VehicleType @default(BIKE)
  isOnline        Boolean     @default(false)
  isVerified      Boolean     @default(false)
  isActive        Boolean     @default(true)
  totalDeliveries Int         @default(0)
  rating          Decimal     @db.Decimal(3, 2) @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  orders     Order[]
  deliveries Delivery[]

  @@index([isOnline, isActive])
}

enum VehicleType {
  WALK
  BIKE
  CAR
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String?       @unique
  deliveryId  String?       @unique
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  reference   String?
  confirmedBy String?
  confirmedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order    Order?    @relation(fields: [orderId], references: [id])
  delivery Delivery? @relation(fields: [deliveryId], references: [id])

  @@index([status])
}

enum PaymentMethod {
  CASH
  QR
  TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

model StorePayout {
  id          String       @id @default(cuid())
  storeId     String
  periodStart DateTime
  periodEnd   DateTime
  grossSales  Decimal      @db.Decimal(12, 2)
  commission  Decimal      @db.Decimal(12, 2)
  netPayout   Decimal      @db.Decimal(12, 2)
  orderCount  Int
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  store       Store        @relation(fields: [storeId], references: [id])
  @@index([storeId, status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  NEW_ORDER
  ORDER_CONFIRMED
  ORDER_READY
  ORDER_ASSIGNED
  ORDER_PICKED_UP
  ORDER_DELIVERED
  PAYMENT_CONFIRM
  NEW_DELIVERY
  SYSTEM
}